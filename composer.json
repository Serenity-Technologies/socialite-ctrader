{
    "name": "serenity_technologies/socialite-ctrader",
    "description": "cTrader Socialite Provider for Laravel Socialite.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Kwadwo Kyeremeh",
            "email": "kyerematics@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1|^8.2|^8.3|^8.4",
        "laravel/socialite": "^5.0",
        "socialiteproviders/manager": "^4.0",
        "google/protobuf": "^5.35"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "SocialiteProviders\\Ctrader\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SocialiteProviders\\Ctrader\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
